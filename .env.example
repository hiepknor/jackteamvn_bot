# ============================================
# Jack Stock Bot Configuration
# ============================================

# Telegram Bot Token (lấy từ @BotFather)
BOT_TOKEN=your_bot_token_here

# Bot Name
BOT_NAME=JackStockBot

# Admin Telegram IDs (comma-separated)
# Lấy user ID từ @userinfobot
# Để trống nếu muốn cho phép tất cả người dùng sử dụng bot
ADMIN_IDS=

# Database Settings
DB_NAME=data/jackteamvn.db
DB_BACKUP_ENABLED=true

# Export Settings
EXPORT_DIR=exports
EXPORT_KEEP_COUNT=10
MAX_EXPORT_ROWS=10000

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/jackteamvn_bot.log

# Rate Limiting
RATE_LIMIT_PER_MINUTE=60
