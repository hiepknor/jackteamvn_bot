# Telegram bot token (lấy từ @BotFather)
BOT_TOKEN=

# Danh sách Telegram user ID quản trị (phân tách bằng dấu phẩy)
ADMIN_IDS=

# SQLite DB path (relative to project root)
DB_NAME=data/jackteamvn.db

# FSM backend: memory hoặc redis
FSM_BACKEND=memory
REDIS_URL=redis://redis:6379/0

# Bật/tắt healthcheck runtime
HEALTHCHECK_ENABLED=true

# Xóa backup cũ hơn N ngày
BACKUP_RETENTION_DAYS=7

# true: chỉ admin được dùng bot; false: mở bot cho user thường
PRIVATE_BOT_MODE=true

# Logging
LOG_LEVEL=INFO

# Các giá trị mặc định khác
BOT_NAME=JackStockBot
DB_BACKUP_ENABLED=true
EXPORT_DIR=exports
STORAGE_DIR=storage
EXPORT_KEEP_COUNT=10
MAX_EXPORT_ROWS=10000
LOG_FILE=logs/jackteamvn_bot.log
RATE_LIMIT_PER_MINUTE=60
